      </div>
      <button class="btn" onclick="loadMotHistory('${v.vrm}')">↻ Refresh</button>
    </div>
    <div id="mot-${v.vrm}" style="margin-top:1rem;">${renderMotTests(v)}</div>
  </div>`).join('');
}

function renderMotTests(v) {
  const tests = v.mot_history?.motTests || (Array.isArray(v.mot_history) ? (v.mot_history[0]?.motTests||[]) : []);
  if (v.mot_history_error) return `<div style="color:var(--red-text);font-size:13px;">⚠ ${v.mot_history_error}</div>`;
  if (!v.mot_history) return `<div style="color:var(--text3);font-size:13px;">Not loaded — click Refresh</div>`;
  if (!tests.length) return `<div style="color:var(--text3);font-size:13px;">No MOT history found</div>`;
  return tests.map((t,idx)=>{
    const passed=t.testResult==='PASSED';
    const date=t.completedDate?new Date(t.completedDate.replace(' ','T')).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}):'';
    const defects=t.defects||t.rfrAndComments||[];
    const fails=defects.filter(r=>['FAIL','MAJOR','DANGEROUS'].includes(r.type));
    const advisories=defects.filter(r=>['ADVISORY','MINOR'].includes(r.type));
    const hasItems=fails.length||advisories.length;
    return `<details class="mot-test" ${idx===0&&hasItems?'open':''}>
      <summary class="mot-test-header">
        <div style="display:flex;align-items:center;gap:8px;">
          <span class="status-badge ${passed?'badge-pass':'badge-fail'}">${passed?'Pass':'Fail'}</span>
          <span style="font-size:13px;font-weight:500;">${date}</span>
          ${t.odometerValue?`<span style="font-size:11px;color:var(--text3);">${Number(t.odometerValue).toLocaleString()} ${t.odometerUnit||'mi'}</span>`:''}
        </div>
        <div style="display:flex;gap:4px;align-items:center;">
          ${fails.length?`<span class="mot-tag fail">${fails.length} fail${fails.length>1?'s':''}</span>`:''}
          ${advisories.length?`<span class="mot-tag advisory">${advisories.length} advisor${advisories.length>1?'ies':'y'}</span>`:''}
          ${hasItems?`<span style="font-size:9px;color:var(--text3);margin-left:2px;">▾</span>`:''}
        </div>
      </summary>
      ${hasItems?`<div style="padding:6px 8px 8px;">
        ${fails.map(f=>`<div class="mot-item fail-item"><span class="mot-item-label">${f.type}</span>${f.text}</div>`).join('')}
        ${advisories.map(a=>`<div class="mot-item advisory"><span class="mot-item-label">Advisory</span>${a.text}</div>`).join('')}
      </div>`:''}
      ${t.expiryDate?`<div style="font-size:11px;color:var(--text3);padding:2px 12px 8px;">Expiry: ${formatDate(t.expiryDate)}</div>`:''}
    </details>`;
  }).join('');
}

async function loadMotHistory(vrm) {
  document.getElementById('mot-'+vrm).innerHTML = '<div style="color:var(--text3);font-size:13px;">Loading…</div>';
  try {
    const res = await fetch('/mot-history/'+vrm);
    const data = await res.json();
    const v = vehicles.find(x=>x.vrm===vrm);
    if (v) {
      v.mot_history = data;
      v.mot_history_error = null;
      await fetch(`/api/vehicles/${vrm}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({mot_history:data,mot_history_fetched:new Date().toISOString(),mot_history_error:null})});
      document.getElementById('mot-'+vrm).innerHTML = renderMotTests(v);
    }
  } catch(e) {
    const v=vehicles.find(x=>x.vrm===vrm);
    if(v){v.mot_history_error='Error loading';document.getElementById('mot-'+vrm).innerHTML=renderMotTests(v);}
  }
}

async function autoLoadMot() {
  for (const v of vehicles) {
    if (!v.mot_history) await loadMotHistory(v.vrm);
  }
}
async function refreshAllMot() {
  for (const v of vehicles) await loadMotHistory(v.vrm);
}

