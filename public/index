<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garage Tracker</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#f4f3ef;--surface:#fff;--surface2:#eeede8;
  --border:rgba(0,0,0,0.10);--border2:rgba(0,0,0,0.18);
  --text:#1a1a18;--text2:#5f5e5a;--text3:#888780;
  --accent:#1a1a18;
  --green-bg:#eaf3de;--green-text:#27500a;--green-border:#3b6d11;
  --amber-bg:#faeeda;--amber-text:#633806;--amber-border:#854f0b;
  --red-bg:#fcebeb;--red-text:#501313;--red-border:#a32d2d;
  --blue-bg:#e6f1fb;--blue-text:#042c53;--blue-border:#185fa5;
  --radius:12px;--radius-sm:8px;
}
@media(prefers-color-scheme:dark){:root{
  --bg:#181816;--surface:#242422;--surface2:#2e2e2b;
  --border:rgba(255,255,255,0.10);--border2:rgba(255,255,255,0.20);
  --text:#f1efe8;--text2:#b4b2a9;--text3:#888780;
  --green-bg:#173404;--green-text:#c0dd97;--green-border:#3b6d11;
  --amber-bg:#412402;--amber-text:#fac775;--amber-border:#854f0b;
  --red-bg:#501313;--red-text:#f7c1c1;--red-border:#a32d2d;
  --blue-bg:#042c53;--blue-text:#b5d4f4;--blue-border:#185fa5;
}}
body{font-family:system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:16px;}

/* ── Auth pages ── */
.auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;}
.auth-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:2rem;width:100%;max-width:400px;}
.auth-logo{display:flex;align-items:center;gap:12px;margin-bottom:2rem;}
.auth-logo-icon{width:44px;height:44px;background:#f5c842;border-radius:10px;display:flex;align-items:center;justify-content:center;}
.auth-logo-title{font-size:22px;font-weight:700;}
.auth-logo-sub{font-size:13px;color:var(--text3);}
.auth-card h2{font-size:20px;font-weight:600;margin-bottom:1.5rem;}
.form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:1rem;}
label{font-size:14px;font-weight:500;color:var(--text2);}
input[type=text],input[type=email],input[type=password],input[type=date],input[type=number]{
  padding:10px 14px;border:0.5px solid var(--border2);border-radius:var(--radius-sm);
  background:var(--surface);color:var(--text);font-size:15px;font-family:inherit;
  outline:none;transition:border-color 0.15s;width:100%;
}
input:focus{border-color:#534ab7;box-shadow:0 0 0 3px rgba(83,74,183,0.12);}
.btn{padding:10px 20px;border-radius:var(--radius-sm);font-size:15px;font-weight:500;cursor:pointer;border:0.5px solid var(--border2);background:var(--surface);color:var(--text);transition:background 0.15s;font-family:inherit;}
.btn:hover{background:var(--surface2);}
.btn-primary{background:var(--text);color:var(--surface);border-color:var(--text);}
.btn-primary:hover{opacity:0.85;}
.btn-danger{background:var(--red-bg);color:var(--red-text);border-color:var(--red-border);}
.btn-full{width:100%;margin-top:0.5rem;}
.auth-error{background:var(--red-bg);color:var(--red-text);border:0.5px solid var(--red-border);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;margin-top:0.75rem;display:none;}

/* ── App shell ── */
#app{display:none;}
header{background:#000;color:#fff;padding:1rem 2rem;display:flex;align-items:center;gap:1rem;}
.header-logo{display:flex;align-items:center;gap:12px;}
.header-icon{width:38px;height:38px;background:#f5c842;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.header-title{font-size:22px;font-weight:700;color:#fff;}
.header-sub{font-size:12px;opacity:0.55;color:#fff;}
.header-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.user-badge{font-size:13px;color:rgba(255,255,255,0.7);}
#dark-toggle{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.25);color:#fff;padding:6px 12px;border-radius:20px;cursor:pointer;font-size:12px;font-weight:500;}
.tabs-wrap{padding:0 2rem;}
@media(max-width:700px){.tabs-wrap{padding:0 1rem;}header{padding:1rem;}}
.tabs{display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:2rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:10px 16px;font-size:14px;white-space:nowrap;font-weight:500;color:var(--text2);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;margin-bottom:-1px;transition:color 0.15s,border-color 0.15s;font-family:inherit;}
.tab.active{color:var(--text);border-bottom-color:var(--text);}
.tab:hover:not(.active){color:var(--text);}
.panel{display:none;}.panel.active{display:block;}
.panel-wrap{padding:0 2rem;}
@media(max-width:700px){.panel-wrap{padding:0 1rem;}}

/* ── Cards ── */
.card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-bottom:1.25rem;}
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;}
@media(min-width:1400px){.card-grid{grid-template-columns:repeat(auto-fill,minmax(380px,1fr));}}
.vehicle-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.vehicle-card-header{padding:1.25rem 1.5rem 1rem;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;}
@font-face{font-family:'UKPlate';src:url('https://cdn.jsdelivr.net/gh/TexelFR/CharlesWright@main/CharlesWright-Bold.woff2') format('woff2');font-weight:bold;}
.vrm{font-family:'UKPlate','Arial Black',sans-serif;font-size:20px;font-weight:900;letter-spacing:0.08em;background:#f5c842;color:#000;padding:5px 12px 4px;border-radius:4px;display:inline-block;border:2px solid #d4a800;text-transform:uppercase;line-height:1.2;position:relative;}
.vrm::before{content:'';position:absolute;left:0;top:0;bottom:0;width:24px;background:#003399;border-radius:2px 0 0 2px;}
.vrm-text{position:relative;padding-left:16px;}
.vrm-input{font-family:'Courier New',monospace;font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;}
.vehicle-name{font-size:13px;color:var(--text2);margin-top:4px;}
.card-actions{display:flex;gap:6px;flex-shrink:0;}
.btn-icon{width:30px;height:30px;border-radius:var(--radius-sm);border:0.5px solid var(--border);background:var(--surface2);color:var(--text2);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;}
.btn-icon:hover{background:var(--border);color:var(--text);}
.status-strips{border-top:0.5px solid var(--border);padding:0.875rem 1.5rem;display:flex;flex-direction:column;gap:8px;}
.status-row{display:flex;align-items:center;justify-content:space-between;font-size:14px;}
.status-label{color:var(--text2);font-weight:500;}
.status-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;border:0.5px solid;white-space:nowrap;}
.badge-ok{background:var(--green-bg);color:var(--green-text);border-color:var(--green-border);}
.badge-soon{background:var(--amber-bg);color:var(--amber-text);border-color:var(--amber-border);}
.badge-expired{background:var(--red-bg);color:var(--red-text);border-color:var(--red-border);}
.badge-unknown{background:var(--surface2);color:var(--text3);border-color:var(--border2);}
.badge-pass{background:var(--green-bg);color:var(--green-text);border-color:var(--green-border);}
.badge-fail{background:var(--red-bg);color:var(--red-text);border-color:var(--red-border);}
.days-text{font-size:12px;color:var(--text3);}
.mot-test{border:0.5px solid var(--border);border-radius:var(--radius-sm);margin-top:6px;overflow:hidden;}
.mot-test-header{padding:9px 12px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;gap:8px;list-style:none;}
.mot-test-header::-webkit-details-marker{display:none;}
.mot-test-header:hover{background:var(--surface2);}
.mot-item{font-size:12px;padding:5px 9px;border-radius:4px;margin:0 8px 4px;border-left:3px solid;line-height:1.5;}
.mot-item.advisory{background:var(--amber-bg);border-color:var(--amber-border);color:var(--amber-text);}
.mot-item.fail-item{background:var(--red-bg);border-color:var(--red-border);color:var(--red-text);}
.mot-item-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;margin-right:5px;}
.mot-tag{font-size:11px;border-radius:10px;padding:1px 7px;border:0.5px solid;white-space:nowrap;}
.mot-tag.fail{background:var(--red-bg);color:var(--red-text);border-color:var(--red-border);}
.mot-tag.advisory{background:var(--amber-bg);color:var(--amber-text);border-color:var(--amber-border);}
.loading-bar{text-align:center;padding:3rem;color:var(--text3);font-size:15px;}
.empty-state{text-align:center;padding:3rem 1rem;color:var(--text3);}
.success-msg{background:var(--green-bg);color:var(--green-text);border:0.5px solid var(--green-border);border-radius:var(--radius-sm);padding:6px 10px;font-size:13px;margin-top:0.75rem;display:none;}
.error-msg{background:var(--red-bg);color:var(--red-text);border:0.5px solid var(--red-border);border-radius:var(--radius-sm);padding:6px 10px;font-size:13px;margin-top:0.75rem;display:none;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
@media(max-width:600px){.form-grid{grid-template-columns:1fr;}}
.form-group.full{grid-column:1/-1;}
.settings-section{margin-bottom:2rem;max-width:560px;}
.settings-section h3{font-size:16px;font-weight:600;margin-bottom:0.75rem;padding-bottom:0.5rem;border-bottom:0.5px solid var(--border);}
.info-box{background:var(--blue-bg);border:0.5px solid var(--blue-border);border-radius:var(--radius-sm);padding:0.75rem 1rem;font-size:14px;color:var(--blue-text);margin-bottom:1rem;line-height:1.6;}

/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;padding:1rem;}
.modal-box{background:var(--surface);border-radius:var(--radius);padding:1.5rem;max-width:480px;width:100%;border:0.5px solid var(--border);}
.modal-title{font-size:15px;font-weight:600;margin-bottom:1.25rem;}
</style>
</head>
<body>

<!-- ── Login page ── -->
<div id="login-page" class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="26" height="26">
          <path d="M5 11L6.5 6.5H17.5L19 11" stroke="#1a1a18" stroke-width="1.5" stroke-linecap="round"/>
          <rect x="3" y="11" width="18" height="7" rx="1.5" stroke="#1a1a18" stroke-width="1.5"/>
          <circle cx="7.5" cy="18" r="1.5" fill="#1a1a18"/>
          <circle cx="16.5" cy="18" r="1.5" fill="#1a1a18"/>
          <path d="M3 14h18" stroke="#1a1a18" stroke-width="1.5"/>
        </svg>
      </div>
      <div>
        <div class="auth-logo-title">Garage Tracker</div>
        <div class="auth-logo-sub">MOT &amp; tax monitor</div>
      </div>
    </div>
    <h2>Sign in</h2>
    <div class="form-group">
      <label>Email address</label>
      <input type="email" id="login-email" placeholder="you@example.com" onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" id="login-password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <button class="btn btn-primary btn-full" onclick="doLogin()">Sign in</button>
    <div class="auth-error" id="login-error"></div>
  </div>
</div>

<!-- ── Main app ── -->
<div id="app">
  <header>
    <div class="header-logo">
      <div class="header-icon">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
          <path d="M5 11L6.5 6.5H17.5L19 11" stroke="#1a1a18" stroke-width="1.5" stroke-linecap="round"/>
          <rect x="3" y="11" width="18" height="7" rx="1.5" stroke="#1a1a18" stroke-width="1.5"/>
          <circle cx="7.5" cy="18" r="1.5" fill="#1a1a18"/>
          <circle cx="16.5" cy="18" r="1.5" fill="#1a1a18"/>
          <path d="M3 14h18" stroke="#1a1a18" stroke-width="1.5"/>
        </svg>
      </div>
      <div>
        <div class="header-title">Garage Tracker</div>
        <div class="header-sub">MOT &amp; tax monitor</div>
      </div>
    </div>
    <div class="header-right">
      <span class="user-badge" id="user-badge"></span>
      <button id="dark-toggle" onclick="toggleDark()">☀️ Light</button>
      <button class="btn" style="background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.25);color:#fff;font-size:12px;padding:6px 12px;" onclick="doLogout()">Sign out</button>
    </div>
  </header>

  <div class="tabs-wrap">
    <div class="tabs">
      <button class="tab active" onclick="switchTab('garage')">My Garage</button>
      <button class="tab" onclick="switchTab('mot')">MOT History</button>
      <button class="tab" onclick="switchTab('lookup')">🔍 Lookup</button>
      <button class="tab" onclick="switchTab('account')">Account</button>
      <button class="tab admin-only" onclick="switchTab('admin')" style="display:none;">⚙️ Admin</button>
    </div>
  </div>

  <div class="panel-wrap">

    <!-- MY GARAGE -->
    <div id="tab-garage" class="panel active">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:8px;">
        <span style="color:var(--text2);font-size:13px;" id="vehicle-count"></span>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="btn" onclick="refreshAllDvla()">↻ Refresh DVLA</button>
          <button class="btn btn-primary" onclick="openAddModal()">+ Add vehicle</button>
        </div>
      </div>
      <div class="card-grid" id="vehicle-cards"><div class="loading-bar">Loading your garage…</div></div>
    </div>

    <!-- MOT HISTORY -->
    <div id="tab-mot" class="panel">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:8px;">
        <span style="color:var(--text2);font-size:13px;" id="mot-count"></span>
        <button class="btn" onclick="refreshAllMot()">↻ Refresh all MOT history</button>
      </div>
      <div id="mot-panels"></div>
    </div>

    <!-- LOOKUP -->
    <div id="tab-lookup" class="panel">
      <div style="max-width:720px;margin:0 auto;">
        <div class="card" style="margin-bottom:1.5rem;">
          <h3 style="font-size:15px;font-weight:600;margin-bottom:1rem;">Instant vehicle lookup</h3>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <input class="vrm-input" type="text" id="lookup-vrm" placeholder="e.g. AB12CDE" maxlength="8" style="flex:1;min-width:120px;" onkeydown="if(event.key==='Enter')doLookup()">
            <button class="btn btn-primary" onclick="doLookup()" id="lookup-btn">Search</button>
          </div>
          <div id="lookup-error" class="error-msg"></div>
        </div>
        <div id="lookup-loading" style="display:none;" class="loading-bar">Looking up vehicle…</div>
        <div id="lookup-result" style="display:none;">
          <div class="card" style="margin-bottom:1.5rem;" id="lookup-dvla-card"></div>
          <div class="card" id="lookup-mot-card"></div>
        </div>
      </div>
    </div>

    <!-- ACCOUNT -->
    <div id="tab-account" class="panel">
      <div style="max-width:560px;">
        <div class="settings-section">
          <h3>Profile</h3>
          <div class="form-group"><label>Name</label><input type="text" id="acc-name"></div>
          <div class="form-group"><label>Email (login)</label><input type="email" id="acc-email" disabled style="opacity:0.6;"></div>
          <div class="form-group"><label>Notification email</label><input type="email" id="acc-notify" placeholder="Where to send alerts"></div>
          <button class="btn btn-primary" onclick="saveProfile()">Save changes</button>
          <div class="success-msg" id="profile-success">Saved!</div>
          <div class="error-msg" id="profile-error"></div>
        </div>
        <div class="settings-section">
          <h3>Change password</h3>
          <div class="form-group"><label>Current password</label><input type="password" id="pw-current"></div>
          <div class="form-group"><label>New password</label><input type="password" id="pw-new"></div>
          <div class="form-group"><label>Confirm new password</label><input type="password" id="pw-confirm"></div>
          <button class="btn btn-primary" onclick="changePassword()">Update password</button>
          <div class="success-msg" id="pw-success">Password updated!</div>
          <div class="error-msg" id="pw-error"></div>
        </div>
        <div class="settings-section">
          <h3>Email notifications</h3>
          <div class="info-box">Alerts are sent to your notification email at 9am daily for MOT, tax, insurance and service reminders at 30, 7 and 1 day before expiry. You'll also get instant alerts for MOT pass/fail and V5C changes.</div>
          <button class="btn" onclick="sendTestEmail()">Send test email</button>
          <div class="success-msg" id="test-success"></div>
        </div>
      </div>
    </div>

    <!-- ADMIN -->
    <div id="tab-admin" class="panel">
      <div style="max-width:720px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
          <h3 style="font-size:16px;font-weight:600;">User accounts</h3>
          <button class="btn btn-primary" onclick="openNewUserModal()">+ Add user</button>
        </div>
        <div id="user-list"></div>
      </div>
    </div>

  </div><!-- end panel-wrap -->
</div><!-- end app -->

<!-- Add vehicle modal -->
<div class="modal-overlay" id="add-modal">
  <div class="modal-box">
    <div class="modal-title">Add a vehicle</div>
    <div class="form-grid">
      <div class="form-group full"><label>Registration number</label><input class="vrm-input" type="text" id="add-vrm" placeholder="e.g. AB12CDE" maxlength="8"></div>
      <div class="form-group full"><label>Nickname (optional)</label><input type="text" id="add-name" placeholder="e.g. Dad's Mondeo"></div>
      <div class="form-group"><label>Insurance expiry</label><input type="date" id="add-insurance"></div>
      <div class="form-group"><label>Insurance provider</label><input type="text" id="add-insurer" placeholder="e.g. Admiral"></div>
      <div class="form-group full"><label>Last service date</label><input type="date" id="add-serviced"></div>
    </div>
    <div style="margin-top:1.25rem;display:flex;gap:10px;">
      <button class="btn btn-primary" onclick="addVehicle()">Add vehicle</button>
      <button class="btn" onclick="closeAddModal()">Cancel</button>
    </div>
    <div class="success-msg" id="add-success">Vehicle added!</div>
    <div class="error-msg" id="add-error"></div>
  </div>
</div>

<!-- Edit vehicle modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal-box">
    <div class="modal-title">Edit vehicle</div>
    <input type="hidden" id="edit-vrm-orig">
    <div class="form-grid">
      <div class="form-group full"><label>Nickname</label><input type="text" id="edit-name"></div>
      <div class="form-group"><label>Insurance expiry</label><input type="date" id="edit-insurance"></div>
      <div class="form-group"><label>Insurance provider</label><input type="text" id="edit-insurer"></div>
      <div class="form-group full"><label>Last service date</label><input type="date" id="edit-serviced"></div>
    </div>
    <div style="margin-top:1.25rem;display:flex;gap:10px;">
      <button class="btn btn-primary" onclick="saveEdit()">Save</button>
      <button class="btn" onclick="closeEditModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- New user modal (admin) -->
<div class="modal-overlay" id="new-user-modal">
  <div class="modal-box">
    <div class="modal-title">Add user account</div>
    <div class="form-group"><label>Name</label><input type="text" id="nu-name" placeholder="Full name"></div>
    <div class="form-group"><label>Email address</label><input type="email" id="nu-email" placeholder="user@example.com"></div>
    <div class="form-group"><label>Password</label><input type="password" id="nu-password" placeholder="Temporary password"></div>
    <div class="form-group"><label>Notification email (optional)</label><input type="email" id="nu-notify" placeholder="Same as login email if blank"></div>
    <div style="margin-top:1.25rem;display:flex;gap:10px;">
      <button class="btn btn-primary" onclick="createUser()">Create account</button>
      <button class="btn" onclick="closeNewUserModal()">Cancel</button>
    </div>
    <div class="success-msg" id="nu-success"></div>
    <div class="error-msg" id="nu-error"></div>
  </div>
</div>

<script>
let vehicles = [], currentUser = null;

// ── Dark mode ──────────────────────────────────────────────────────────────────
function applyTheme(dark) {
  const r = document.documentElement;
  const props = dark
    ? {'--bg':'#181816','--surface':'#242422','--surface2':'#2e2e2b','--border':'rgba(255,255,255,0.10)','--border2':'rgba(255,255,255,0.20)','--text':'#f1efe8','--text2':'#b4b2a9','--text3':'#888780','--green-bg':'#173404','--green-text':'#c0dd97','--green-border':'#3b6d11','--amber-bg':'#412402','--amber-text':'#fac775','--amber-border':'#854f0b','--red-bg':'#501313','--red-text':'#f7c1c1','--red-border':'#a32d2d','--blue-bg':'#042c53','--blue-text':'#b5d4f4','--blue-border':'#185fa5'}
