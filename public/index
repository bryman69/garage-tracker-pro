function renderMotTab() {
  const el = document.getElementById('mot-panels');
  document.getElementById('mot-count').textContent = vehicles.length + ' vehicle' + (vehicles.length!==1?'s':'');
  el.innerHTML = vehicles.map(v => `<div class="card" style="margin-bottom:1rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
      <div>
        <span class="vrm" style="font-size:16px;"><span class="vrm-text">${v.vrm}</span></span>
