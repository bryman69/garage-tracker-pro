// ── Helpers ────────────────────────────────────────────────────────────────────
function formatDate(d) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'});
}
function daysUntil(d) {
  if (!d) return null;
  const now = new Date(); now.setHours(0,0,0,0);
  return Math.ceil((new Date(d)-now)/86400000);
}
function svcDue(last) {
  if (!last) return null;
  const d = new Date(last); d.setFullYear(d.getFullYear()+1);
  return d.toISOString().split('T')[0];
}
function daysText(d) {
  if (d===null) return '';
  if (d<0) return `<span class="days-text">${Math.abs(d)}d ago</span>`;
  return `<span class="days-text">${d}d</span>`;
}
function statusBadge(d) {
  if (d===null) return `<span class="status-badge badge-unknown">Unknown</span>`;
  if (d<0) return `<span class="status-badge badge-expired">Expired</span>`;
  if (d<=30) return `<span class="status-badge badge-soon">Due soon</span>`;
  return `<span class="status-badge badge-ok">OK</span>`;
}

