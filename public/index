            <div style="display:flex;gap:4px;">
              ${fails.length?`<span class="mot-tag fail">${fails.length} fail${fails.length>1?'s':''}</span>`:''}
              ${advisories.length?`<span class="mot-tag advisory">${advisories.length} advisor${advisories.length>1?'ies':'y'}</span>`:''}
              ${hasItems?`<span style="font-size:9px;color:var(--text3);">▾</span>`:''}
            </div>
          </summary>
          ${hasItems?`<div style="padding:6px 8px 8px;">
            ${fails.map(f=>`<div class="mot-item fail-item"><span class="mot-item-label">${f.type}</span>${f.text}</div>`).join('')}
            ${advisories.map(a=>`<div class="mot-item advisory"><span class="mot-item-label">Advisory</span>${a.text}</div>`).join('')}
          </div>`:''}
          ${t.expiryDate?`<div style="font-size:11px;color:var(--text3);padding:2px 12px 8px;">Expiry: ${formatDate(t.expiryDate)}</div>`:''}
        </details>`;
      }).join(''):'<div style="color:var(--text3);font-size:13px;">No MOT history found</div>');
    document.getElementById('lookup-result').style.display='block';
  } catch(e) {
    const el=document.getElementById('lookup-error'); el.textContent=e.message; el.style.display='block';
  } finally {
    document.getElementById('lookup-loading').style.display='none';
    document.getElementById('lookup-btn').disabled=false;
  }
}

async function addFromLookup(vrm) {
  const btn = event.target; btn.disabled=true; btn.textContent='Adding…';
  const res = await fetch('/api/vehicles',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({vrm})});
  if (res.ok) {
    await loadVehicles();
    btn.parentElement.innerHTML='<span style="font-size:13px;color:var(--green-text);background:var(--green-bg);border:0.5px solid var(--green-border);border-radius:6px;padding:5px 12px;">✓ Added to My Garage</span>';
    refreshDvla(vrm);
  } else { btn.disabled=false; btn.textContent='+ Add to My Garage'; }
}

// ── Account ────────────────────────────────────────────────────────────────────
async function saveProfile() {
  const name=document.getElementById('acc-name').value.trim();
  const notify_email=document.getElementById('acc-notify').value.trim();
  const res=await fetch('/api/me',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,notify_email})});
  if(res.ok){showMsg('profile-success','Saved!');currentUser.name=name;document.getElementById('user-badge').textContent=name||currentUser.email;}
  else{const d=await res.json();showMsg('profile-error',d.error);}
}
async function changePassword() {
  const current=document.getElementById('pw-current').value;
  const nw=document.getElementById('pw-new').value;
  const confirm=document.getElementById('pw-confirm').value;
  if(nw!==confirm){showMsg('pw-error','Passwords do not match');return;}
  if(nw.length<8){showMsg('pw-error','Password must be at least 8 characters');return;}
  const res=await fetch('/api/me',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({current_password:current,new_password:nw})});
  if(res.ok){showMsg('pw-success','Password updated!');['pw-current','pw-new','pw-confirm'].forEach(id=>document.getElementById(id).value='');}
  else{const d=await res.json();showMsg('pw-error',d.error);}
}
async function sendTestEmail() {
  const res=await fetch('/test-email');
  const text=await res.text();
  const el=document.getElementById('test-success');el.textContent=text;el.style.display='block';
  setTimeout(()=>el.style.display='none',5000);
}

// ── Admin ──────────────────────────────────────────────────────────────────────
async function loadAdminUsers() {
  const res=await fetch('/api/admin/users');
  const users=await res.json();
  document.getElementById('user-list').innerHTML=users.map(u=>`
    <div class="card" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;padding:1rem 1.25rem;">
      <div>
        <div style="font-weight:500;">${u.name||'(no name)'} ${u.is_admin?'<span style="font-size:11px;background:var(--amber-bg);color:var(--amber-text);border:0.5px solid var(--amber-border);border-radius:4px;padding:1px 6px;">Admin</span>':''}</div>
        <div style="font-size:13px;color:var(--text2);">${u.email}</div>
        <div style="font-size:12px;color:var(--text3);">Notifications: ${u.notify_email||'not set'}</div>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;">
        <button class="btn" style="font-size:13px;padding:6px 12px;" onclick="resetPassword('${u.id}','${u.email}')">Reset password</button>
        ${!u.is_admin?`<button class="btn btn-danger" style="font-size:13px;padding:6px 12px;" onclick="deleteUser('${u.id}','${u.email}')">Delete</button>`:''}
      </div>
    </div>`).join('');
}
function openNewUserModal(){document.getElementById('new-user-modal').style.display='flex';setTimeout(()=>document.getElementById('nu-name').focus(),50);}
function closeNewUserModal(){document.getElementById('new-user-modal').style.display='none';['nu-name','nu-email','nu-password','nu-notify'].forEach(id=>document.getElementById(id).value='');document.getElementById('nu-success').style.display='none';document.getElementById('nu-error').style.display='none';}
async function createUser() {
  const name=document.getElementById('nu-name').value.trim();
  const email=document.getElementById('nu-email').value.trim();
  const password=document.getElementById('nu-password').value;
  const notify_email=document.getElementById('nu-notify').value.trim()||email;
  if(!email||!password){showMsg('nu-error','Email and password required');return;}
  const res=await fetch('/api/admin/users',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,email,password,notify_email})});
  const data=await res.json();
  if(res.ok){showMsg('nu-success',`Account created for ${data.email}`);loadAdminUsers();}
  else{showMsg('nu-error',data.error);}
}
async function deleteUser(id,email) {
  if(!confirm(`Delete account for ${email}? This will remove all their vehicles too.`))return;
  await fetch(`/api/admin/users/${id}`,{method:'DELETE'});
  loadAdminUsers();
}
async function resetPassword(id,email) {
  const pw=prompt(`New password for ${email}:`);
  if(!pw||pw.length<8){alert('Password must be at least 8 characters');return;}
  const res=await fetch(`/api/admin/users/${id}/reset-password`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:pw})});
  if(res.ok)alert(`Password reset for ${email}`);
}

// ── Utils ──────────────────────────────────────────────────────────────────────
function showMsg(id,msg){const el=document.getElementById(id);if(!el)return;el.textContent=msg;el.style.display='block';setTimeout(()=>el.style.display='none',4000);}

// ── Boot ───────────────────────────────────────────────────────────────────────
checkAuth();
</script>
