    <div class="status-row"><span class="status-label">MOT</span><div style="display:flex;align-items:center;gap:6px;">${daysText(motD)}${statusBadge(motD)}</div></div>
    ${v.mot_expiry?`<div style="font-size:11px;color:var(--text3);margin-top:-4px;">Expires ${formatDate(v.mot_expiry)}</div>`:''}
    <div class="status-row"><span class="status-label">Tax</span><div style="display:flex;align-items:center;gap:6px;">${daysText(taxD)}${statusBadge(taxD)}</div></div>
    ${v.tax_expiry?`<div style="font-size:11px;color:var(--text3);margin-top:-4px;">Due ${formatDate(v.tax_expiry)}</div>`:''}
    <div class="status-row"><span class="status-label">Service</span><div style="display:flex;align-items:center;gap:6px;">${daysText(svcD)}${statusBadge(svcD)}</div></div>
    ${v.last_serviced?`<div style="font-size:11px;color:var(--text3);margin-top:-4px;">Last ${formatDate(v.last_serviced)} — due ${formatDate(svcDate)}</div>`:`<div style="font-size:11px;color:var(--text3);margin-top:-4px;">No service date recorded</div>`}
    <div class="status-row"><span class="status-label">Insurance</span><div style="display:flex;align-items:center;gap:6px;">${daysText(insD)}${statusBadge(insD)}</div></div>
    ${v.insurance_expiry?`<div style="font-size:11px;color:var(--text3);margin-top:-4px;">Expires ${formatDate(v.insurance_expiry)}${v.insurer?' · '+v.insurer:''}</div>`:''}
    ${v.v5c_date?`<div class="status-row" style="margin-top:4px;"><span class="status-label">V5C issued</span><span style="font-size:13px;color:var(--text2);">${formatDate(v.v5c_date)}</span></div>`:''}
  </div>
  ${v.dvla_error?`<div style="margin:0 1.25rem 0.5rem;font-size:11px;color:var(--red-text);background:var(--red-bg);border:0.5px solid var(--red-border);border-radius:4px;padding:4px 8px;">⚠ ${v.dvla_error}</div>`:''}
  <div style="font-size:11px;color:var(--text3);padding:0 1.25rem 0.75rem;">DVLA updated: ${fetched}</div>
</div>`;
}

