}

// ── DVLA refresh ───────────────────────────────────────────────────────────────
async function refreshDvla(vrm) {
  const v = vehicles.find(x=>x.vrm===vrm);
  if (v) { v._loading=true; renderVehicles(); }
  try {
    const res = await fetch('/lookup',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({registrationNumber:vrm})});
    const data = await res.json();
    if (data.errors || data.error) { await fetch(`/api/vehicles/${vrm}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({dvla_error:data.errors?.[0]?.detail||data.error||'Unknown error'})}); }
    else {
      const u={make:data.make,colour:data.colour,mot_expiry:data.motExpiryDate,tax_expiry:data.taxDueDate,dvla_fetched:new Date().toISOString(),dvla_error:null};
      await fetch(`/api/vehicles/${vrm}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(u)});
    }
  } catch(e) {}
  await loadVehicles();
}

async function refreshAllDvla() {
  const btn = document.querySelector('button[onclick="refreshAllDvla()"]');
  if(btn){btn.disabled=true;btn.textContent='Refreshing…';}
  for (const v of vehicles) await refreshDvla(v.vrm);
  if(btn){btn.disabled=false;btn.textContent='↻ Refresh DVLA';}
}

